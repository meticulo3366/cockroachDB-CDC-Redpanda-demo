# Optional overrides for the demo. Copy to `.env` to use:  cp .env.example .env
# docker compose automatically reads `.env` in this directory.

# Generator throughput: interval between events and an optional hard cap.
GENERATE_INTERVAL=100ms   # ~10 orders/sec
GENERATE_COUNT=0          # 0 = run forever; set e.g. 1000 to produce a fixed batch
